# Global Configuration values for KubePilot Autonomous Kubernetes SRE Platform

# Redis Config
REDIS_HOST=redis-master.kubepilot-system.svc.cluster.local
REDIS_PORT=6379
REDIS_PASSWORD=

# Postgres Config
POSTGRES_USER=kubepilot
POSTGRES_PASSWORD=kubepilot_secret
POSTGRES_DB=kubepilot_db
POSTGRES_HOST=postgres-db.kubepilot-system.svc.cluster.local
POSTGRES_PORT=5432

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.kubepilot-observability.svc.cluster.local:4317

# Security
JWT_SECRET=kubepilot_super_secret_enterprise_key_2026

# AI Config
OLLAMA_HOST=http://ollama.kubepilot-system.svc.cluster.local:11434
OLLAMA_MODEL=llama3.1:8b
# GEMINI_API_KEY=
